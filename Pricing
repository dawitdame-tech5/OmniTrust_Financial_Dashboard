// ── Main update ──────────────────────────────────────────────────
function update2(){
  S.totalPop  = parseInt(document.getElementById('totalPop').value)||2600000;
  S.age       = parseFloat(document.getElementById('ageElig').value);
  S.svc       = parseFloat(document.getElementById('svcCov').value);
  S.freq      = parseFloat(document.getElementById('freq').value);
  S.rev       = parseFloat(document.getElementById('revEvt').value)||1.42;
  S.startYear = parseInt(document.getElementById('startYear').value)||2026;
  S.y1        = parseFloat(document.getElementById('y1Adopt').value);
  S.max       = parseFloat(document.getElementById('maxAdopt').value);
  S.spd       = parseInt(document.getElementById('rampSpd').value);
  if(S.y1>S.max){S.y1=S.max;document.getElementById('y1Adopt').value=S.max;}

  document.getElementById('v_age').textContent  = S.age+'%';
  document.getElementById('v_svc').textContent  = S.svc+'%';
  document.getElementById('v_freq').textContent = (+S.freq).toFixed(1)+' / yr';
  document.getElementById('v_y1').textContent   = S.y1.toFixed(1)+'%';
  document.getElementById('v_max').textContent  = S.max+'%';
  document.getElementById('v_spd').textContent  = S.spd;

  const appPop=S.totalPop*(S.age/100)*(S.svc/100);
  document.getElementById('applicablePop').textContent=fC(Math.round(appPop));
  const rates=adoptRates2(S.y1,S.max,S.spd,S.model);
  drawSpark2(rates);

  const rows=[],years=[],t5=[],ot75=[],vols=[];
  for(let i=0;i<10;i++){
    const yr=S.startYear+i, a=rates[i];
    const e=appPop*(a/100), v=e*S.freq, r=v*S.rev;
    rows.push({year:yr,adopt:a,enrolled:Math.round(e),volume:Math.round(v),revenue:r});
    years.push(yr); t5.push(r*0.25); ot75.push(r*0.75); vols.push(Math.round(v));
  }
  lastRows2=rows;

  const rev10=rows.reduce((s,r)=>s+r.revenue,0);
  const rev5 =rows.slice(0,5).reduce((s,r)=>s+r.revenue,0);
  const vol10=vols.reduce((a,b)=>a+b,0);
  const cagr =vols[0]>0?(Math.pow(vols[9]/vols[0],1/9)-1)*100:0;

  document.getElementById('kRev10').textContent  = fM(rev10);
  document.getElementById('kRev5').textContent   = fM(rev5);
  document.getElementById('kVol10').textContent  = fN(vol10);
  document.getElementById('kCAGR').textContent   = cagr.toFixed(1)+'%';
  document.getElementById('kT5_10').textContent  = fM(rev10*0.25);
  document.getElementById('kT5_5').textContent   = fM(rev5*0.25);
  document.getElementById('kEnr10').textContent  = fN(rows[9].enrolled);
  document.getElementById('kRevY10').textContent = fM(rows[9].revenue);

  const u=UC[S.uc];
  document.getElementById('chartTtl').textContent=u.icon+' '+u.label+' — Revenue Build-up';
  document.getElementById('tblTtl').textContent  =u.icon+' '+u.label+' — Annual Detail';
  drawChart2(years,t5,ot75,vols);
  drawTable2(rows,Math.round(appPop));

  document.getElementById('footnote').textContent=
    `Applicable Pop = ${fC(S.totalPop)} × ${S.age}% age bracket × ${S.svc}% ID coverage = ${fC(Math.round(appPop))}  ·  `+
    `Ramp: ${S.model==='linear'?'Linear':'S-Curve'}  ·  Volume = enrolled × ${S.freq.toFixed(1)} events/yr  ·  `+
    `OT Revenue = volume × $${S.rev.toFixed(2)}/event (${S_tier})  ·  TECH5-SA = 25% SPV share`;

  if(window.OT_SYNC){OT_SYNC.tab3Rev10=rev10;OT_SYNC.tab3Rev5=rev5;}
}

// ── CSV export ───────────────────────────────────────────────────
function exportCSV(){
  const u=UC[S.uc], ap=S.totalPop*(S.age/100)*(S.svc/100);
  let csv=`OmniTrust Volume & Revenue — TECH5-SA\nCountry,${S_ctry}\nUse Case,${u.label}\neKYC Tier,${S_tier}\n`;
  csv+=`OT Rev/Event,$${S.rev}\nTotal Population,${S.totalPop}\nApplicable Pop,${Math.round(ap)}\n\n`;
  csv+='Year,Applicable Pop,Adoption %,Enrolled,Event Volume,OT Revenue,TECH5-SA 25%,Cumul TECH5-SA\n';
  let ct5=0;
  lastRows2.forEach(r=>{
    ct5+=r.revenue*0.25;
    csv+=`${r.year},${Math.round(ap)},${r.adopt.toFixed(2)},${r.enrolled},${r.volume},${r.revenue.toFixed(2)},${(r.revenue*0.25).toFixed(2)},${ct5.toFixed(2)}\n`;
  });
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download=`OmniTrust_Vol_${S_ctry}_${S.uc}.csv`; a.click();
}
