    </nav>
  </div>
</div>
<script>
function switchTab(n){
  document.querySelectorAll('.tab').forEach((t,i)=>{
    t.classList.toggle('act',i===n);
    t.setAttribute('aria-selected',i===n);
  });
  document.querySelectorAll('.tab-panel').forEach((p,i)=>p.classList.toggle('act',i===n));
}

// ── Cross-tab shared state ──
window.OT_SYNC = { txPrice:null, txCost:null, country:null, otr:null, tab3Rev:null, tab3Vol:null };
</script>

<!-- ── Tab panels ── -->
<div id="panel-0" role="tabpanel" class="tab-panel act">

