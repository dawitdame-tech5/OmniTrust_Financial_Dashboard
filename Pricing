#panel-2 .shell {display:flex;height:calc(100vh - 50px);}
#panel-2 .inp {width:348px;flex-shrink:0;border-right:1px solid var(--line);overflow-y:auto;background:#FAFBFC;}
#panel-2 .inp::-webkit-scrollbar {width:3px;}
#panel-2 .inp::-webkit-scrollbar-thumb {background:var(--line);}
#panel-2 .out {flex:1;overflow-y:auto;padding:20px 26px;background:var(--bg);}
#panel-2 .out::-webkit-scrollbar {width:3px;}
#panel-2 .out::-webkit-scrollbar-thumb {background:var(--line);}
#panel-2 .sec {padding:15px 17px;border-bottom:1px solid var(--line);}
#panel-2 .sec-lbl {font-size:9.5px;font-weight:700;letter-spacing:0.13em;text-transform:uppercase;color:var(--navy);display:inline-block;margin-bottom:12px;padding-bottom:4px;border-bottom:2px solid var(--orange);}
#panel-2 .uc-grid {display:grid;grid-template-columns:1fr 1fr;gap:6px;}
#panel-2 .uc-card {background:var(--white);border:1px solid var(--line);border-left:2px solid transparent;border-radius:3px;padding:9px 10px;cursor:pointer;transition:border-color .12s,background .12s;}
#panel-2 .uc-card:hover {border-color:var(--line);border-left-color:var(--orange);background:var(--orange-dim);}
#panel-2 .uc-card.active {border-color:var(--line);border-left:3px solid var(--orange);background:var(--orange-dim);}
#panel-2 .uc-icon {font-size:15px;line-height:1;margin-bottom:4px;}
#panel-2 .uc-name {font-size:11px;font-weight:700;color:var(--navy);line-height:1.3;}
#panel-2 .uc-desc {font-size:9.5px;color:var(--text-2);margin-top:2px;line-height:1.3;}
#panel-2 .drv {margin-bottom:13px;}
#panel-2 .drv:last-of-type {margin-bottom:0;}
#panel-2 .drv-hdr {display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;}
#panel-2 .drv-name {font-size:12px;color:var(--text-2);font-weight:600;}
#panel-2 .drv-val {font-family:var(--mono);font-size:12.5px;font-weight:700;color:var(--navy);}
#panel-2 input[type=range] {-webkit-appearance:none;width:100%;height:3px;background:var(--line);border-radius:2px;outline:none;cursor:pointer;}
#panel-2 input[type=range]::-webkit-slider-thumb {-webkit-appearance:none;width:13px;height:13px;background:var(--navy);border-radius:50%;border:2px solid var(--white);box-shadow:0 1px 4px rgba(27,58,106,0.25);cursor:pointer;}
#panel-2 input[type=range].oth::-webkit-slider-thumb {background:var(--orange);box-shadow:0 1px 4px rgba(242,101,34,0.3);}
#panel-2 .range-tks {display:flex;justify-content:space-between;margin-top:3px;}
#panel-2 .range-tks span {font-size:9px;color:var(--text-3);}
#panel-2 .computed {background:var(--teal-dim);border:1px solid rgba(0,103,103,0.17);border-radius:3px;padding:8px 12px;display:flex;justify-content:space-between;align-items:center;margin-top:9px;}
#panel-2 .computed-l {font-size:11px;color:var(--teal);font-weight:700;}
#panel-2 .computed-v {font-family:var(--mono);font-size:15px;font-weight:700;color:var(--teal);}
#panel-2 .numinput {display:flex;align-items:center;background:var(--white);border:1px solid var(--line);border-radius:3px;overflow:hidden;}
#panel-2 .numinput input {background:transparent;border:none;outline:none;color:var(--navy);font-family:var(--mono);font-size:12.5px;font-weight:700;padding:7px 11px;width:100%;}
#panel-2 .numinput input::-webkit-inner-spin-button {-webkit-appearance:none;}
#panel-2 .numinput-unit {font-size:9.5px;color:var(--text-3);padding:0 10px 0 0;white-space:nowrap;}
#panel-2 .rev-row {display:flex;align-items:center;gap:9px;margin-top:4px;}
#panel-2 .rev-input-wrap {display:flex;align-items:center;background:var(--white);border:1px solid var(--line);border-radius:3px;overflow:hidden;flex:1;}
#panel-2 .rev-input-wrap input {background:transparent;border:none;outline:none;color:var(--text-2);font-family:var(--mono);font-size:12px;font-weight:600;padding:5px 9px;width:100%;}
#panel-2 .rev-input-wrap input::-webkit-inner-spin-button {-webkit-appearance:none;}
#panel-2 .tog-row {display:flex;gap:5px;margin-bottom:12px;}
#panel-2 .tbtn {flex:1;padding:6px;border:1px solid var(--line);background:var(--white);color:var(--text-2);border-radius:3px;font-size:11px;font-weight:700;cursor:pointer;text-align:center;transition:all .12s;font-family:var(--sans);letter-spacing:0.03em;}
#panel-2 .tbtn.active {background:var(--navy);border-color:var(--navy);color:#FFF;}
#panel-2 .tbtn:hover:not(.active) {border-color:var(--navy);color:var(--navy);}
#panel-2 .spark {background:var(--white);border:1px solid var(--line);border-radius:3px;padding:9px 11px;margin-top:12px;}
#panel-2 .spark-hdr {display:flex;justify-content:space-between;font-size:10px;color:var(--text-3);margin-bottom:6px;}
#panel-2 .spark-ann {font-weight:700;color:var(--navy);}
#panel-2 .spark-yrs {display:flex;justify-content:space-between;margin-top:4px;}
#panel-2 .spark-yrs span {font-size:9px;color:var(--text-3);}
#panel-2 .kpi-section {margin-bottom:14px;}
#panel-2 .kpi-section-lbl {font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-3);margin-bottom:6px;padding-left:2px;}
#panel-2 .kpi-row {display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-bottom:6px;}
#panel-2 .kpi {background:var(--white);border:1px solid var(--line);border-top:3px solid var(--navy);border-radius:3px;padding:12px 13px;}
#panel-2 .kpi.orange {border-top-color:var(--orange);}
#panel-2 .kpi.teal {border-top-color:var(--teal);}
#panel-2 .kpi.t5 {border-top-color:var(--orange);background:var(--orange-dim);}
#panel-2 .kpi.dim {opacity:.78;}
#panel-2 .kpi-lbl {font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.10em;color:var(--text-3);margin-bottom:4px;}
#panel-2 .kpi-val {font-family:var(--mono);font-size:18px;font-weight:700;color:var(--navy);line-height:1;}
#panel-2 .kpi.orange .kpi-val, #panel-2 .kpi.t5 .kpi-val {color:var(--orange);}
#panel-2 .kpi-unit {font-size:10px;color:var(--text-3);margin-top:3px;}
#panel-2 .chart-card {background:var(--white);border:1px solid var(--line);border-radius:3px;padding:15px 19px;margin-bottom:15px;}
#panel-2 .chart-hdr {display:flex;justify-content:space-between;align-items:center;margin-bottom:13px;}
#panel-2 .chart-ttl {font-size:13px;font-weight:700;color:var(--navy);}
#panel-2 .legend {display:flex;gap:14px;}
#panel-2 .leg {display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text-2);}
#panel-2 .leg-dot {width:10px;height:10px;border-radius:2px;}
#panel-2 .tbl-card {background:var(--white);border:1px solid var(--line);border-radius:3px;overflow:hidden;margin-bottom:16px;}
#panel-2 .tbl-hdr-row {display:flex;justify-content:space-between;align-items:center;padding:11px 17px;background:var(--navy);border-bottom:2px solid var(--orange);}
#panel-2 .tbl-ttl {font-size:13px;font-weight:700;color:#FFF;}
#panel-2 .tbl-sub {font-size:10px;color:rgba(255,255,255,0.45);}
#panel-2 .tbl-card table {width:100%;border-collapse:collapse;}
#panel-2 .tbl-card th {font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:0.09em;color:var(--text-3);padding:8px 17px;text-align:right;border-bottom:1px solid var(--line);background:#FAFBFC;white-space:nowrap;}
#panel-2 .tbl-card th:first-child {text-align:left;}
#panel-2 .tbl-card td {padding:7px 17px;font-size:12px;font-family:var(--mono);text-align:right;color:var(--text-1);border-bottom:1px solid var(--line-light);}
#panel-2 .tbl-card td:first-child {font-family:var(--sans);font-weight:700;font-size:12.5px;text-align:left;color:var(--navy);}
#panel-2 .tbl-card tr:last-child td {border-bottom:none;}
#panel-2 .tbl-card tr:nth-child(even) td {background:#FAFBFC;}
#panel-2 .tbl-card tr:hover td {background:var(--navy-dim);}
#panel-2 .c-navy {color:var(--navy);}
#panel-2 .c-orange {color:var(--orange);}
#panel-2 .c-teal {color:var(--teal);}
#panel-2 .c-dim {color:var(--text-3);font-style:italic;}
#panel-2 .abar {display:inline-block;height:3px;background:linear-gradient(90deg,var(--navy),var(--teal));border-radius:2px;vertical-align:middle;margin-right:5px;opacity:0.55;}
#panel-2 .footnote {font-size:9.5px;color:var(--text-3);padding:0 0 14px;}
#panel-2 .ctry-sel {width:100%;font-size:13px;font-weight:700;padding:8px 10px;border:1px solid var(--line);border-radius:3px;background:var(--white);color:var(--navy);cursor:pointer;font-family:var(--sans);margin-bottom:10px;}
#panel-2 .ctry-meta {display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;}
#panel-2 .ctry-badge {font-size:10px;font-weight:700;padding:3px 8px;border-radius:2px;white-space:nowrap;}
#panel-2 .ctry-badge.arch {background:var(--navy-dim);color:var(--navy);}
#panel-2 .ctry-badge.pop {background:var(--orange-dim);color:var(--orange);}
#panel-2 .ctry-badge.otr {background:var(--teal-dim);color:var(--teal);}
#panel-2 .sync-bar {display:flex;align-items:center;gap:8px;padding:8px 10px;background:var(--navy-dim);border-radius:3px;margin-bottom:10px;}
#panel-2 .sync-lbl {font-size:9.5px;font-weight:700;color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;margin-right:2px;}
#panel-2 .sync-btn {font-size:10px;font-weight:700;padding:4px 10px;border:1px solid var(--line);border-radius:2px;background:var(--white);color:var(--text-2);cursor:pointer;transition:all .12s;}
#panel-2 .sync-btn:hover {border-color:var(--orange);color:var(--orange);}
#panel-2 .sync-ok {border-color:var(--teal)!important;color:var(--teal)!important;}
#panel-2 .tier-row {display:flex;gap:4px;margin-top:6px;}
#panel-2 .tier-row .tbtn {padding:4px 9px;font-size:10px;letter-spacing:.04em;}

</style>

<div class="shell">
  <!-- ══ INPUT PANEL ══ -->
  <div class="inp">

    <!-- 00 Country -->
    <div class="sec">
      <div class="sec-lbl">00 — Country</div>
      <select class="ctry-sel" id="ctrySelect" onchange="loadCountry(this.value)"></select>
      <div class="ctry-meta">
        <span class="ctry-badge arch" id="ctryArch">—</span>
        <span class="ctry-badge pop"  id="ctryPop">—</span>
        <span class="ctry-badge otr"  id="ctryOtr">—</span>
      </div>
      <div class="sync-bar">
        <span class="sync-lbl">Sync</span>
        <button class="sync-btn" id="syncT1Btn" onclick="syncFromTab1()" title="Pull default $/event for active use case from Tab 1 pricing model">← Tab 1 price</button>
        <button class="sync-btn" id="syncT2Btn" onclick="syncFromTab2()" title="Load country clicked in Tab 2 eKYC matrix">← Tab 2 country</button>
        <button class="sync-btn" onclick="exportCSV()" style="margin-left:auto">↓ CSV</button>
      </div>
    </div>

    <!-- 01 Use Case -->
    <div class="sec">
      <div class="sec-lbl">01 — Use Case</div>
      <div class="uc-grid" id="ucGrid"></div>
    </div>

    <!-- 02 Population Drivers -->
    <div class="sec">
      <div class="sec-lbl">02 — Population Drivers</div>
      <div class="drv">
        <div class="drv-hdr"><span class="drv-name">Total Population</span></div>
        <div class="numinput">
          <input type="number" id="totalPop" value="2600000" min="10000" step="100000">
          <span class="numinput-unit">persons</span>
        </div>
      </div>
      <div class="drv">
        <div class="drv-hdr">
          <span class="drv-name">Eligible Age Bracket</span>
          <span class="drv-val" id="v_age">70%</span>
        </div>
        <input type="range" id="ageElig" min="30" max="95" step="1" value="70">
        <div class="range-tks"><span>30%</span><span>share of pop. aged 15+</span><span>95%</span></div>
      </div>
      <div class="drv">
        <div class="drv-hdr">
          <span class="drv-name">ID / Service Coverage</span>
          <span class="drv-val" id="v_svc">80%</span>
        </div>
        <input type="range" id="svcCov" min="5" max="100" step="1" value="80">
        <div class="range-tks"><span>5%</span><span>enrolled / reachable</span><span>100%</span></div>
      </div>
      <div class="computed">
        <span class="computed-l">Applicable Population</span>
        <span class="computed-v" id="applicablePop">—</span>
      </div>
    </div>

    <!-- 03 Event Drivers -->
    <div class="sec">
      <div class="sec-lbl">03 — Event Drivers</div>
      <div class="drv">
        <div class="drv-hdr">
          <span class="drv-name">Event Frequency</span>
          <span class="drv-val" id="v_freq">1.0 / yr</span>
        </div>
        <input type="range" id="freq" min="0.1" max="52" step="0.1" value="1.0">
        <div class="range-tks"><span>0.1</span><span>events per enrolled user per year</span><span>52</span></div>
      </div>
      <div class="drv" style="margin-bottom:0">
        <div class="drv-hdr" style="margin-bottom:4px">
          <span class="drv-name">OT Revenue / Event</span>
          <span style="font-size:9px;color:var(--text-3)" id="revSrc">eKYC T1 · BWA</span>
        </div>
        <div class="rev-row">
          <div class="rev-input-wrap">
            <input type="number" id="revEvt" value="1.42" min="0.001" step="0.01">
          </div>
          <span style="font-size:9.5px;color:var(--text-3);white-space:nowrap">USD</span>
        </div>
        <div class="tier-row" id="tierRow">
          <button class="tbtn active" id="tierT1" onclick="setEkycTier('T1')">T1 eKYC</button>
          <button class="tbtn"        id="tierT2" onclick="setEkycTier('T2')">T2 + anchor</button>
          <button class="tbtn"        id="tierT3" onclick="setEkycTier('T3')">T3 + 2nd</button>
        </div>
      </div>
      <div class="drv" style="margin-top:13px;margin-bottom:0">
        <div class="drv-hdr"><span class="drv-name">Projection Start Year</span></div>
        <div class="numinput" style="max-width:150px">
          <input type="number" id="startYear" value="2026" min="2020" max="2040" step="1">
        </div>
      </div>
    </div>

    <!-- 04 Adoption Ramp -->
    <div class="sec">
      <div class="sec-lbl">04 — Adoption Ramp</div>
      <div class="tog-row">
        <button class="tbtn" id="btnLin" onclick="setModel('linear')">Linear</button>
        <button class="tbtn active" id="btnScv" onclick="setModel('scurve')">S-Curve</button>
      </div>
      <div class="drv">
        <div class="drv-hdr">
          <span class="drv-name">Year 1 Adoption Rate</span>
          <span class="drv-val" id="v_y1">2.0%</span>
        </div>
        <input type="range" class="oth" id="y1Adopt" min="0.1" max="25" step="0.1" value="2">
        <div class="range-tks"><span>0.1%</span><span>of applicable population in year 1</span><span>25%</span></div>
      </div>
      <div class="drv">
        <div class="drv-hdr">
          <span class="drv-name">Maximum Adoption Ceiling</span>
          <span class="drv-val" id="v_max">35%</span>
        </div>
        <input type="range" class="oth" id="maxAdopt" min="5" max="95" step="1" value="35">
        <div class="range-tks"><span>5%</span><span>long-run ceiling</span><span>95%</span></div>
      </div>
      <div class="drv">
        <div class="drv-hdr">
          <span class="drv-name" id="rampLbl">Inflection Year (S-Curve)</span>
          <span class="drv-val" id="v_spd">5</span>
        </div>
        <input type="range" class="oth" id="rampSpd" min="2" max="9" step="1" value="5">
        <div class="range-tks"><span>2 yrs</span><span></span><span>9 yrs</span></div>
      </div>
      <div class="spark">
        <div class="spark-hdr">
          <span>Adoption Curve Preview</span>
          <span class="spark-ann" id="sparkAnn">—</span>
        </div>
        <svg id="sparkSvg" width="100%" height="48" viewBox="0 0 300 48" preserveAspectRatio="none"></svg>
        <div class="spark-yrs"><span>Y1</span><span>Y3</span><span>Y5</span><span>Y7</span><span>Y10</span></div>
      </div>
    </div>

  </div><!-- /inp -->

  <!-- ══ OUTPUT PANEL ══ -->
  <div class="out">

    <!-- KPI — OmniTrust Revenue row -->
    <div class="kpi-section">
      <div class="kpi-section-lbl">OmniTrust SPV Revenue</div>
      <div class="kpi-row">
        <div class="kpi orange">
          <div class="kpi-lbl">10-Year Cumulative</div>
          <div class="kpi-val" id="kRev10">—</div>
          <div class="kpi-unit">OT revenue · USD</div>
        </div>
        <div class="kpi orange dim">
          <div class="kpi-lbl">5-Year Cumulative</div>
          <div class="kpi-val" id="kRev5">—</div>
          <div class="kpi-unit">OT revenue · USD</div>
        </div>
        <div class="kpi">
          <div class="kpi-lbl">10-Year Volume</div>
          <div class="kpi-val" id="kVol10">—</div>
          <div class="kpi-unit">cumulative events</div>
        </div>
        <div class="kpi">
          <div class="kpi-lbl">Volume CAGR</div>
          <div class="kpi-val" id="kCAGR">—</div>
          <div class="kpi-unit">Y1 → Y10</div>
        </div>
      </div>
    </div>

    <!-- KPI — TECH5-SA share row -->
    <div class="kpi-section">
      <div class="kpi-section-lbl">TECH5-SA 25% SPV Share</div>
      <div class="kpi-row">
        <div class="kpi t5">
          <div class="kpi-lbl">10-Year Share</div>
          <div class="kpi-val" id="kT5_10">—</div>
          <div class="kpi-unit">TECH5-SA 25% · USD</div>
        </div>
        <div class="kpi t5 dim">
          <div class="kpi-lbl">5-Year Share</div>
          <div class="kpi-val" id="kT5_5">—</div>
          <div class="kpi-unit">TECH5-SA 25% · USD</div>
        </div>
        <div class="kpi teal">
          <div class="kpi-lbl">Year 10 Enrolled</div>
          <div class="kpi-val" id="kEnr10">—</div>
          <div class="kpi-unit">active users</div>
        </div>
        <div class="kpi">
          <div class="kpi-lbl">Year 10 Ann. Revenue</div>
          <div class="kpi-val" id="kRevY10">—</div>
          <div class="kpi-unit">OT · Year 10 only</div>
        </div>
      </div>
    </div>

    <!-- Chart — stacked bar -->
    <div class="chart-card">
      <div class="chart-hdr">
        <span class="chart-ttl" id="chartTtl">Revenue Build-up — 10-Year</span>
        <div class="legend">
          <div class="leg"><div class="leg-dot" style="background:rgba(242,101,34,.9)"></div>TECH5-SA 25%</div>
          <div class="leg"><div class="leg-dot" style="background:rgba(27,58,106,.8)"></div>OmniTrust 75%</div>
          <div class="leg"><div class="leg-dot" style="background:#006767;opacity:.7"></div>Event Vol</div>
        </div>
      </div>
      <div style="height:250px;position:relative;">
        <canvas id="volChart"></canvas>
      </div>
    </div>

    <!-- Table -->
    <div class="tbl-card">
      <div class="tbl-hdr-row">
        <span class="tbl-ttl" id="tblTtl">Annual Projection Detail</span>
        <span class="tbl-sub" id="tblSub"></span>
      </div>
      <table>
        <thead><tr>
          <th>Year</th>
          <th>Applicable Pop</th>
          <th>Adoption %</th>
          <th>Enrolled</th>
          <th>Event Volume</th>
          <th>OT Revenue</th>
          <th>TECH5-SA 25%</th>
          <th>Cumul. TECH5-SA</th>
        </tr></thead>
        <tbody id="tblBody"></tbody>
        <tfoot id="tblFoot"></tfoot>
      </table>
    </div>
    <div class="footnote" id="footnote"></div>
  </div><!-- /out -->
</div><!-- /shell -->

<script>

const CTRY=[
  {c:'BWA',n:'Botswana',         f:'🇧🇼',p:2600000,   arch:'Hummingbird',age:70,cov:80,otr:1.42},
  {c:'COM',n:'Comoros',          f:'🇰🇲',p:850000,    arch:'Hummingbird',age:62,cov:30,otr:2.60},
