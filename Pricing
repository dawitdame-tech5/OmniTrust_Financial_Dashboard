const regCls={Africa:'reg-Africa',MENA:'reg-MENA','S. Asia':'reg-SA','SE Asia':'reg-SEA',Americas:'reg-Americas',Pacific:'reg-Pacific'};
const rlCls={yes:'rail-yes',partial:'rail-partial',nascent:'rail-nascent',none:'rail-none'};
const rlLbl={yes:'Mature',partial:'Partial',nascent:'Nascent',none:'None'};
const tcls={1:'src-t1',2:'src-t2',3:'src-t3'};

function stars(n){const r=Math.round(n);return '★'.repeat(r)+'<span style="opacity:.2">'+'★'.repeat(5-r)+'</span>';}
function dcls(s){return s>=4.5?'dpi-5':s>=3.8?'dpi-4':s>=3.0?'dpi-3':s>=2.0?'dpi-2':'dpi-1';}
function svcls(p){return p>=50?'sv-high':p>=35?'sv-mid':'sv-low';}

let rF='all',rlF='all',omniF='all',srtMode='dpi-desc';

function ekycRender(){
  let rows=DATA.filter(d=>(rF==='all'||d.region===rF)&&(rlF==='all'||d.rl===rlF)&&(omniF==='all'||d.omni===true));
  const sf={'dpi-desc':(a,b)=>b.dpi-a.dpi,'savings-desc':(a,b)=>{const sa=((a.blo+a.bhi)/2-a.otr)/((a.blo+a.bhi)/2);const sb=((b.blo+b.bhi)/2-b.otr)/((b.blo+b.bhi)/2);return sb-sa;},'bench-desc':(a,b)=>((b.blo+b.bhi)/2)-((a.blo+a.bhi)/2),'margin-desc':(a,b)=>((b.otr-b.otc)/b.otr)-((a.otr-a.otc)/a.otr),'country':(a,b)=>a.country.localeCompare(b.country)};
  rows.sort(sf[srtMode]);
  const usedRefs=new Set();
  const pipelineCount=rows.filter(d=>d.omni).length;
  document.getElementById('tableBody').innerHTML=rows.map(d=>{
    const mid=+((d.blo+d.bhi)/2).toFixed(2);
    const sv=Math.round((mid-d.otr)/mid*100);
    const mg=Math.round((d.otr-d.otc)/d.otr*100);
    const uniqueSrc=[...new Map(d.src.map(s=>[s.r,s])).values()];
    uniqueSrc.forEach(s=>usedRefs.add(s.r));
    const pills=uniqueSrc.map(s=>`<span class="src-pill ${tcls[s.t]}">${s.l}</span>`).join('');
    const omniDot=d.omni?'<span class="omni-dot" title="OmniTrust pipeline"></span>':'';
    return `<tr class="${d.omni?'omni-row':''}" style="cursor:${d.omni?'pointer':'default'}" onclick="${d.omni?`if(window.OT_SYNC){OT_SYNC.country='${d.country}';OT_SYNC.otr=${d.otr};}`:''}">
      <td><div class="country-cell"><span class="flag">${d.flag}</span><span class="country-name">${d.country}</span>${omniDot}</div></td>
      <td><span class="reg-badge ${regCls[d.region]}">${d.region}</span></td>
      <td><div><span class="rail-badge ${rlCls[d.rl]}">${rlLbl[d.rl]}</span><div class="rail-name">${d.rln}</div></div></td>
      <td><div class="cov-cell"><div class="cov-pct">${d.cov}%</div><div class="cov-bar-bg"><div class="cov-bar-fill" style="width:${d.cov}%"></div></div></div></td>
      <td><span class="stars-cell">${stars(d.rc)}</span></td>
      <td><span class="vol-badge vol-${d.vol}">${d.vol==='L'?'Large':d.vol==='M'?'Medium':'Small'}</span></td>
      <td><div class="bench-mid">$${mid.toFixed(2)}</div><div class="bench-range">$${d.blo.toFixed(2)}–$${d.bhi.toFixed(2)}/check</div></td>
      <td><div class="ot-rate">$${d.otr.toFixed(2)}</div><div class="ot-cost">cost $${d.otc.toFixed(2)} *</div></td>
      <td><span class="savings-badge ${svcls(sv)}">${sv}%</span></td>
      <td><span class="margin-badge">${mg}% *</span></td>
      <td><div class="dpi-circle ${dcls(d.dpi)}">${d.dpi.toFixed(1)}</div></td>
      <td><div class="src-pills">${pills}</div></td>
    </tr>`;
  }).join('');
  document.getElementById('tableCount').textContent=`${rows.length} markets shown · ${pipelineCount} pipeline`;
  document.getElementById('kpiP').textContent=pipelineCount;
  if(rows.length>0){
    const ab=rows.reduce((s,d)=>s+(d.blo+d.bhi)/2,0)/rows.length;
    const ao=rows.reduce((s,d)=>s+d.otr,0)/rows.length;
    const asv=rows.reduce((s,d)=>{const m=(d.blo+d.bhi)/2;return s+(m-d.otr)/m*100;},0)/rows.length;
    const amg=rows.reduce((s,d)=>s+(d.otr-d.otc)/d.otr*100,0)/rows.length;
    document.getElementById('kpi0').textContent='$'+ab.toFixed(2);
    document.getElementById('kpi1').textContent='$'+ao.toFixed(2);
    document.getElementById('kpi2').textContent=Math.round(asv)+'%';
    document.getElementById('kpi3').textContent=Math.round(amg)+'% *';
  }
  const wb=Object.keys(ALL_SOURCES).filter(k=>ALL_SOURCES[k].tier===1&&usedRefs.has(k));
  const rg=Object.keys(ALL_SOURCES).filter(k=>ALL_SOURCES[k].tier===2&&usedRefs.has(k));
  const cm=Object.keys(ALL_SOURCES).filter(k=>ALL_SOURCES[k].tier===3&&usedRefs.has(k));
  const mkGrp=(title,refs)=>refs.length===0?'':`<div class="src-group"><div class="src-group-title">${title}</div>${refs.map(r=>`<div class="src-entry"><b>${r}</b> ${ALL_SOURCES[r].text}</div>`).join('')}</div>`;
  document.getElementById('sourcesList').innerHTML=mkGrp('Tier 1 — World Bank / Multilateral',wb)+mkGrp('Tier 2 — Regulatory / National authority',rg)+mkGrp('Tier 3 — Commercial provider benchmarks',cm);
}

document.querySelectorAll('#panel-1 [data-omni]').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('#panel-1 [data-omni]').forEach(x=>x.classList.remove('active'));b.classList.add('active');omniF=b.dataset.omni;ekycRender();}));
