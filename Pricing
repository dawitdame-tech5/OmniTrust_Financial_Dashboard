/* Use case browser */
.uc-controls{display:flex;gap:8px;align-items:center;margin-bottom:10px;flex-wrap:wrap}
.uc-search{flex:1;min-width:180px;font-size:11px;padding:5px 9px;border-radius:6px;border:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary);color:var(--color-text-primary)}
.uc-search:focus{outline:none;border-color:var(--color-border-secondary)}
