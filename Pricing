/* ════════════════════════════════════════════════════════════
   TECH5 BRAND FACELIFT
   Palette sourced from TECH5 Branding Guidelines v1
   Orange #F26522 · Navy #1B3A6A · Dark teal #003148 · Green #006767
   ════════════════════════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap');

:root {
  --t5-orange:    #F26522;
  --t5-orange-dk: #C9521A;
  --t5-orange-lt: #FEF0E8;
  --t5-navy:      #1B3A6A;
  --t5-navy-dk:   #003148;
  --t5-navy-lt:   #EEF2F8;
  --t5-teal:      #006767;
  --t5-teal-lt:   #E0F0F0;
  --t5-text:      #3C3C3B;
  --t5-text-md:   #5A5A58;
  --t5-text-lt:   #9B9B98;
  --t5-bg:        #F0F2F5;
  --t5-border:    rgba(27,58,106,.13);
  --t5-border-md: rgba(27,58,106,.22);
  --t5-shadow:    0 1px 3px rgba(27,58,106,.09),0 1px 2px rgba(27,58,106,.05);

  /* Override v7 tokens */
  --color-background-primary:   #FFFFFF;
  --color-background-secondary: #F0F2F5;
  --color-background-info:      #EEF2F8;
  --color-text-primary:         #3C3C3B;
  --color-text-secondary:       #5A5A58;
  --color-text-success:         #006767;
  --color-text-info:            #1B3A6A;
  --color-border-tertiary:      rgba(27,58,106,.11);
  --color-border-secondary:     rgba(27,58,106,.22);
  --color-border-info:          #1B3A6A;
}

/* ── Body ── */
body {
  background: var(--t5-bg);
  font-family: 'Barlow', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

/* ── Tab bar ── */
.tabbar {
  background:
    url("data:image/svg+xml,%3Csvg width='56' height='48' viewBox='0 0 56 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpolygon points='28,1 55,15 55,43 28,47 1,43 1,15' fill='none' stroke='rgba(255,255,255,0.06)' stroke-width='1'/%3E%3C/svg%3E") 0 0 / 56px 48px,
    linear-gradient(135deg, #1B3A6A 0%, #003148 60%, #006767 100%);
  border-bottom: none;
  box-shadow: 0 3px 16px rgba(0,0,0,.28);
  margin: -24px -24px 24px;
}
.tabbar-inner { padding: 0 24px; }

/* ── Tab logo ── */
.tab-logo {
  color: #FFFFFF;
  font-family: 'Barlow Condensed', 'Barlow', sans-serif;
  font-weight: 700;
  font-size: 13.5px;
  letter-spacing: .4px;
  border-right: 0.5px solid rgba(255,255,255,.2);
  padding: 14px 20px 14px 0;
  margin-right: 8px;
  line-height: 1.2;
  display: flex;
  flex-direction: column;
  gap: 1px;
}
.tab-logo .t5-product { color: rgba(255,255,255,.55); font-size: 10px; font-weight: 500; letter-spacing: .8px; text-transform: uppercase; }
.tab-logo .t5-brand   { color: #FFFFFF; display: flex; align-items: center; gap: 5px; }
.tab-logo .t5-name    { color: var(--t5-orange); }

/* ── Tabs ── */
.tab {
  color: rgba(255,255,255,.6);
  font-family: 'Barlow', sans-serif;
  font-size: 12.5px;
  font-weight: 500;
  letter-spacing: .2px;
  padding: 14px 18px;
  border-bottom: 2.5px solid transparent;
  transition: color .15s, border-color .15s, background .15s;
}
.tab:hover { color: rgba(255,255,255,.9); background: rgba(255,255,255,.07); }
.tab.act   { color: #FFFFFF; border-bottom-color: var(--t5-orange); background: rgba(255,255,255,.09); }

/* ── Panels ── */
.pnl {
  border: 0.5px solid var(--t5-border);
  box-shadow: var(--t5-shadow);
  border-radius: 10px;
}

/* ── Section labels ── */
.sl {
  color: var(--t5-navy);
  font-weight: 700;
  font-size: 11.5px;
  letter-spacing: .25px;
  text-transform: uppercase;
}

/* ── pehd section dividers ── */
.pehd {
  color: var(--t5-text-lt);
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: .7px;
  text-transform: uppercase;
}
.pehd::after { background: rgba(242,101,34,.3); height: 1px; }

/* ── Generic buttons ── */
.pb:hover, .pb.act {
  background: var(--t5-orange-lt);
  color: var(--t5-orange-dk);
  border-color: var(--t5-orange);
}

/* ── Pattern chips ── */
.pchip.act { background: var(--t5-orange-lt); color: var(--t5-orange-dk); border-color: var(--t5-orange); }

/* ── Service picker ── */
.sprow.son { border-color: var(--t5-border); background: var(--t5-bg); }
.sptot { border-top-color: var(--t5-border-md); }

/* ── UC list ── */
.uc-item.sel { background: var(--t5-navy-lt); }
.uc-item.sel .uc-nm { color: var(--t5-navy); font-weight: 600; }
.uc-search, .uc-sel {
  border-color: var(--t5-border);
  background: #FFFFFF;
  color: var(--t5-text);
  font-family: 'Barlow', sans-serif;
}
.uc-search:focus, .uc-sel:focus { border-color: var(--t5-navy); }

/* ── Matrix ── */
.mt tr.msel td { background: var(--t5-navy-lt); }
.mt tr.msel td.lc { color: var(--t5-navy); }

/* ── Breakdown ── */
.bk th { color: var(--t5-text-lt); font-weight: 700; letter-spacing: .5px; }
.bk td.tt { color: var(--t5-teal); font-weight: 700; }
.bk .totrow td { border-top-color: var(--t5-border-md); }

/* ── Derivation table ── */
.dt td.drv { color: var(--t5-teal); }
.dt td.gm  { color: var(--t5-teal); }
.ctot { color: var(--t5-teal); font-weight: 700; }

/* ── Range sliders ── */
input[type=range] { accent-color: var(--t5-orange); }

/* ── SVG tree cost labels ── */
/* override via JS color is fine; these are targeted below */
.pnl .sl::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 11px;
  background: var(--t5-orange);
  border-radius: 2px;
  margin-right: 7px;
  vertical-align: middle;
}

/* ── Inputs ── */
input[type=number]:focus { border-color: var(--t5-navy); }

/* ── Platform fraud box ── */
.pf { background: var(--t5-bg); border-color: var(--t5-border); border-radius: 8px; }

/* ── UC count badge ── */
.uc-count { color: var(--t5-text-lt); }

</style>
</head>
