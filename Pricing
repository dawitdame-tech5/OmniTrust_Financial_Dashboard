// ── Adoption rates ───────────────────────────────────────────────
function adoptRates2(y1,maxA,spd,model){
  const out=[];
  if(model==='linear'){
    const inc=(maxA-y1)/Math.max(spd-1,1);
    for(let n=1;n<=10;n++) out.push(Math.min(y1+(n-1)*inc,maxA));
  } else {
    const ratio=maxA/y1-1;
    const k=ratio>0.001?Math.log(ratio)/Math.max(spd-1,0.5):0.5;
    for(let n=1;n<=10;n++) out.push(Math.min(Math.max(maxA/(1+Math.exp(-k*(n-spd))),0.01),maxA));
  }
  return out;
}

// ── Sparkline ────────────────────────────────────────────────────
function drawSpark2(rates){
  const svg=document.getElementById('sparkSvg');
  const W=300,H=48,PX=5,PY=5,maxR=Math.max(...rates)||1;
  const pts=rates.map((r,i)=>[PX+(i/9)*(W-2*PX),PY+(1-r/maxR)*(H-2*PY)]);
  const line=pts.map((p,i)=>(i?'L':'M')+p[0].toFixed(1)+' '+p[1].toFixed(1)).join('');
  const area=line+` L${pts[9][0].toFixed(1)} ${H} L${pts[0][0].toFixed(1)} ${H} Z`;
  svg.innerHTML=`<defs><linearGradient id="sg3" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="#1B3A6A" stop-opacity="0.18"/>
    <stop offset="100%" stop-color="#1B3A6A" stop-opacity="0"/></linearGradient></defs>
    <path d="${area}" fill="url(#sg3)"/>
    <path d="${line}" fill="none" stroke="#F26522" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
    ${pts.map((p,i)=>`<circle cx="${p[0].toFixed(1)}" cy="${p[1].toFixed(1)}" r="${i===0||i===9?2.5:1.5}" fill="${i===9?'#1B3A6A':'#F26522'}" opacity="${i===0||i===9?1:0.45}"/>`).join('')}`;
  document.getElementById('sparkAnn').textContent=`Y1: ${rates[0].toFixed(1)}%  →  Y10: ${rates[9].toFixed(1)}%`;
}

