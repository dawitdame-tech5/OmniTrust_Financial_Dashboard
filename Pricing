  {c:'ETH',n:'Ethiopia',         f:'🇪🇹',p:129000000, arch:'Blue Whale', age:62,cov:25,otr:1.95},
  {c:'FJI',n:'Fiji',             f:'🇫🇯',p:930000,    arch:'Hummingbird',age:68,cov:65,otr:1.85},
  {c:'GTM',n:'Guatemala',        f:'🇬🇹',p:17600000,  arch:'Gazelle',    age:66,cov:70,otr:1.20},
  {c:'HND',n:'Honduras',         f:'🇭🇳',p:10200000,  arch:'Gazelle',    age:68,cov:72,otr:1.20},
  {c:'IDN',n:'Indonesia',        f:'🇮🇩',p:276000000, arch:'Blue Whale', age:70,cov:78,otr:0.88},
