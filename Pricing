<script>
// Build sector list for dropdown
const SECTORS = [...new Set(UC_DATA.map(u=>u.sector))].sort();
const sel = document.getElementById('uc-sector');
SECTORS.forEach(s => {
  const o=document.createElement('option');o.value=s;
  const n=UC_DATA.filter(u=>u.sector===s).length;
  o.textContent=`${s} (${n})`;sel.appendChild(o);
});

// Pattern definitions — sequential, exhaustive, mutually exclusive (164 total)
const PATTERNS=[
  {id:'onboarding',   label:'Onboarding',   desc:'eKYC + CI — new identity & credential issuance',             color:'var(--ci-s)',  bg:'var(--ci-f)',  match:s=> s.ekyc && s.ci},
  {id:'id_check',     label:'ID check',     desc:'eKYC, no CI — check identity against data anchor or record', color:'var(--k-s)',   bg:'var(--k-f)',   match:s=> s.ekyc && !s.ci},
  {id:'auth_only',    label:'Auth only',    desc:'Auth alone — authentication or payment, no issuance/verify', color:'var(--a-s)',   bg:'var(--a-f)',   match:s=> s.auth && !s.ekyc && !s.ci && !s.cv},
  {id:'verification', label:'Verification', desc:'CV + Auth, no eKYC/CI — verify existing credential',         color:'var(--cv-s)',  bg:'var(--cv-f)',  match:s=> s.cv && s.auth && !s.ekyc && !s.ci},
  {id:'renewal',      label:'Renewal',      desc:'CI + Auth, no eKYC — update credential on existing identity',color:'var(--np-s)', bg:'var(--np-f)',  match:s=> s.ci && s.auth && !s.ekyc && !s.cv},
  {id:'lifecycle',    label:'Lifecycle',    desc:'CI + CV + Auth — full credential renewal / update cycle',    color:'var(--py-s)', bg:'var(--py-f)',  match:s=> s.ci && s.cv && s.auth},
];
let activePattern=null;

function getPattern(svcs){
  for(const p of PATTERNS){if(p.match(svcs))return p.id;}
  return null;
}

function renderPatternChips(preFiltered){
  const counts={};
  PATTERNS.forEach(p=>counts[p.id]=0);
  preFiltered.forEach(u=>{const pid=getPattern(u.svcs);if(pid)counts[pid]++;});
  document.getElementById('pattern-chips').innerHTML=PATTERNS.map(p=>{
    const n=counts[p.id];
    if(!n)return '';
    const act=activePattern===p.id;
    return`<button class="pchip${act?' act':''}" title="${p.desc}"
      style="${act?`background:${p.bg};color:${p.color};border-color:${p.color}`:''}"
      onclick="togglePattern('${p.id}')">${p.label} <span style="opacity:.65">${n}</span></button>`;
  }).join('');
}

function togglePattern(id){activePattern=activePattern===id?null:id;renderUCList();}

function ucCost(svcs) {
  let t=0;
  if(svcs.ekyc)t+=EKYC[svcs.ekyc]||0;
  if(svcs.ci)  t+=r2(BASE.ci+(LOA_CRED[svcs.ci]||0));
  if(svcs.cv)  t+=r2(BASE.cv+(LOA_CRED[svcs.cv]||0));
  if(svcs.auth)t+=r2(BASE.auth+(LOA_AUTH[svcs.auth]||0));
  if(svcs.pay) t+=BASE.pay;
  return r2(t);
}

function renderUCList() {
  const q=(document.getElementById('uc-search').value||'').toLowerCase();
  const sc=document.getElementById('uc-sector').value;
  // Pre-pattern filter (for chip counts)
  const preFiltered=UC_DATA.filter(u=>{
    if(sc && u.sector!==sc) return false;
    if(q && !u.name.toLowerCase().includes(q) && !u.id.toLowerCase().includes(q) && !u.sector.toLowerCase().includes(q)) return false;
    return true;
  });
  renderPatternChips(preFiltered);
  // Apply pattern filter
  const filtered=activePattern?preFiltered.filter(u=>getPattern(u.svcs)===activePattern):preFiltered;
  document.getElementById('uc-count').textContent=`${filtered.length} of ${UC_DATA.length}`;
  const list=document.getElementById('uc-list');
  if(!filtered.length){list.innerHTML=`<div style="padding:12px;font-size:11px;color:var(--color-text-secondary);text-align:center">No results</div>`;return;}
  let html='',lastSec='';
  filtered.forEach(u=>{
    if(u.sector!==lastSec){
      if(lastSec) html+=`</div>`;
      html+=`<div style="padding:4px 9px 2px;font-size:9px;font-weight:600;color:var(--color-text-secondary);background:var(--color-background-secondary);letter-spacing:.04em;border-bottom:0.5px solid var(--color-border-tertiary)">${u.sector}</div>`;
      lastSec=u.sector;
    }
    const cost=ucCost(u.svcs);
    const badges=Object.entries(u.svcs).filter(([k,v])=>v).map(([k,v])=>
      `<span class="uc-b" style="background:${SVC_BGS[k]};color:${SVC_COLORS[k]}">${k==='ekyc'?'eKYC':k.toUpperCase()} ${v}</span>`).join('');
    // Pattern dot
    const pid=getPattern(u.svcs);
    const pat=pid?PATTERNS.find(p=>p.id===pid):null;
    const dot=pat?`<span style="width:6px;height:6px;border-radius:50%;background:${pat.color};flex-shrink:0;display:inline-block;margin-right:2px" title="${pat.label}"></span>`:'';
    html+=`<div class="uc-item${activeUC===u.id?' sel':''}" onclick="applyUC('${u.id}')">
      ${dot}<span class="uc-code">${u.id}</span>
      <span class="uc-nm">${u.name}</span>
      <span class="uc-badges">${badges}</span>
      <span class="uc-cost">${fp2(cost)}</span>
    </div>`;
  });
  list.innerHTML=html;
}

function applyUC(id) {
  const uc=UC_DATA.find(u=>u.id===id);if(!uc)return;
  activeUC=id;
  Object.keys(SVCS).forEach(k=>{
    if(uc.svcs[k]){SVCS[k].on=true;SVCS[k].loa=uc.svcs[k];}
    else{SVCS[k].on=false;}
  });
  renderUCList();renderPicker();renderBreakdown();renderTree();
}

// Service picker, tree, breakdown, cost build-up (unchanged from v6)
function svcCost(k){if(!SVCS[k].on)return 0;if(k==='ekyc')return EKYC[SVCS.ekyc.loa]||0;if(k==='ci')return r2(BASE.ci+(LOA_CRED[SVCS.ci.loa]||0));if(k==='cv')return r2(BASE.cv+(LOA_CRED[SVCS.cv.loa]||0));if(k==='auth')return r2(BASE.auth+(LOA_AUTH[SVCS.auth.loa]||0));if(k==='pay')return BASE.pay;return 0;}
const calcTotal=()=>Object.keys(SVCS).reduce((s,k)=>s+svcCost(k),0);
function getNodes(){const n=[];if(SVCS.ekyc.on){const t=SVCS.ekyc.loa;n.push({type:'ekyc',label:`eKYC ${t}`,desc:ekycDesc(t),base:EKYC[t],addon:0,total:EKYC[t]});}if(SVCS.ci.on){const l=SVCS.ci.loa;n.push({type:'ci',label:'CI',desc:`Issuance · ${l}`,base:BASE.ci,addon:LOA_CRED[l]||0,total:BASE.ci+(LOA_CRED[l]||0)});}if(SVCS.cv.on){const l=SVCS.cv.loa;n.push({type:'cv',label:'CV',desc:`Verification · ${l}`,base:BASE.cv,addon:LOA_CRED[l]||0,total:BASE.cv+(LOA_CRED[l]||0)});}if(SVCS.auth.on){const l=SVCS.auth.loa;n.push({type:'auth',label:'Auth',desc:`Auth · ${l}`,base:BASE.auth,addon:LOA_AUTH[l]||0,total:BASE.auth+(LOA_AUTH[l]||0)});}if(SVCS.pay.on){n.push({type:'pay',label:'Pay',desc:'Flat fee',base:BASE.pay,addon:0,total:BASE.pay});}return n;}
function getTxnName(){if(activeUC){const u=UC_DATA.find(u=>u.id===activeUC);if(u)return u.name.length>32?u.name.slice(0,31)+'…':u.name;}const on=Object.keys(SVCS).filter(k=>SVCS[k].on);if(!on.length)return 'No services selected';if(on.length===1&&on[0]==='auth')return 'Authentication';if(on.includes('ekyc')&&on.includes('ci'))return 'ID onboarding';if(on.includes('cv')&&on.includes('auth'))return 'ID verification';return `Custom (${on.length})`;}
function getMaxLoA(){const rank={'L0':0,'flat':0,'T1':1,'L1':1,'T2':2,'L2':2,'T3':3,'L3':3};let max=0,ml='L0';Object.keys(SVCS).filter(k=>SVCS[k].on).forEach(k=>{const r=rank[SVCS[k].loa]||0;if(r>max){max=r;ml=SVCS[k].loa;}});return ml;}
function toggleSvc(k){SVCS[k].on=!SVCS[k].on;if(SVCS[k].on){const m=SVC_META[k];if(m.opts.length)SVCS[k].loa=m.defLoa;}activeUC=null;renderUCList();renderPicker();renderBreakdown();renderTree();}
function setLoa(k,loa){if(!SVCS[k].on)SVCS[k].on=true;SVCS[k].loa=loa;activeUC=null;renderUCList();renderPicker();renderBreakdown();renderTree();}
function renderPicker(){let h='';Object.keys(SVCS).forEach(k=>{const s=SVCS[k],m=SVC_META[k],on=s.on;h+=`<div class="sprow${on?' son':''}" onclick="toggleSvc('${k}')"><div class="spic" style="border-color:${on?m.color:'var(--color-border-secondary)'};${on?`background:${m.color}`:''}"></div><div class="spnm" style="color:${on?m.color:'var(--color-text-secondary)'}">${m.label}</div><div class="sploas">${m.opts.map(opt=>{const sel=on&&s.loa===opt;return`<button class="splb${sel?' spon':''}" style="${sel?`background:${m.color};color:#fff;border-color:${m.color};font-weight:500`:`opacity:${on?1:0.3};pointer-events:${on?'auto':'none'}`}" onclick="event.stopPropagation();setLoa('${k}','${opt}')">${opt}</button>`;}).join('')}${m.opts.length===0?`<span style="font-size:10px;color:${on?m.color:'var(--color-text-secondary)'};opacity:${on?1:0.4}">flat</span>`:''}</div><div class="spcost">${on?fp2(svcCost(k)):'—'}</div></div>`;});const tot=calcTotal(),on=Object.keys(SVCS).filter(k=>SVCS[k].on).length;h+=`<div class="sptot"><span style="font-size:11px;color:var(--color-text-secondary)">${on} service${on!==1?'s':''} · ${getMaxLoA()}</span><span style="font-size:14px;font-weight:500;color:var(--color-text-success);font-family:var(--font-mono)">${fp2(tot)}</span></div>`;document.getElementById('picker').innerHTML=h;}
function renderBreakdown(){const nodes=getNodes(),tot=calcTotal();if(!nodes.length){document.getElementById('bktbl').innerHTML=`<tr><td colspan="5" style="padding:10px 8px;font-size:11px;color:var(--color-text-secondary);font-style:italic">Select a use case or toggle services above</td></tr>`;return;}let h=`<thead><tr><th>Service</th><th>LoA / Tier</th><th class="r">Base</th><th class="r">Add-on</th><th class="r">Total</th></tr></thead><tbody>`;nodes.forEach(nd=>{const k=nd.type,m=SVC_META[k],hasAddon=nd.addon>0;h+=`<tr><td class="nd" style="color:${m.color}">${nd.label}</td><td><span class="eb" style="color:${m.color};border-color:${m.color};background:${m.bg}">${SVCS[k].loa||'—'}</span></td><td class="r">${hasAddon?fp2(nd.base):'—'}</td><td class="r">${hasAddon?'+'+fp2(nd.addon):nd.type==='pay'?'flat fee':'—'}</td><td class="tt">${fp2(nd.total)}</td></tr>`;});h+=`</tbody><tfoot><tr class="totrow"><td colspan="4" style="text-align:right;font-weight:500;font-size:11px;color:var(--color-text-secondary)">Transaction total</td><td class="tt" style="font-size:13px">${fp2(tot)}</td></tr></tfoot>`;document.getElementById('bktbl').innerHTML=h;}
function renderTree(){const nodes=getNodes(),nn=nodes.length;if(!nn){document.getElementById('trsvg').innerHTML=`<div style="height:80px;display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--color-text-secondary)">Select a use case to visualize</div>`;document.getElementById('trlbl').textContent='';document.getElementById('trtot').textContent='';return;}const tot=calcTotal(),name=getTxnName(),maxLoA=getMaxLoA();document.getElementById('trlbl').textContent=`${name}  ·  ${nn} node${nn!==1?'s':''}`;document.getElementById('trtot').textContent=fp2(tot);const svgH=Math.max(130,nn*82+48),cy=svgH/2,TOP=42;const nYs=nn===1?[cy]:nodes.map((_,i)=>TOP+i*(svgH-2*TOP)/(nn-1));const PX=46,PR=18,EX=92,EW=160,EH=50,SX=318,SW=148,SH=50,ECX=EX+EW/2,SCX=SX+SW/2,MX=(EX+EW+SX)/2,TPX=476;const SV={ekyc:'k',ci:'ci',cv:'cv',auth:'a',pay:'py'};let s=`<defs><marker id="arr6b" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></marker></defs>`;s+=`<line x1="${PX+PR}" y1="${cy}" x2="${EX}" y2="${cy}" stroke="var(--color-border-secondary)" stroke-width="1" fill="none" marker-end="url(#arr6b)"/>`;nodes.forEach((_,i)=>{const ny=nYs[i];s+=`<path d="M ${EX+EW} ${cy} C ${MX} ${cy} ${MX} ${ny} ${SX} ${ny}" stroke="var(--color-border-secondary)" stroke-width="0.8" fill="none"/>`;s+=`<circle cx="${SX}" cy="${ny}" r="2.5" style="fill:var(--${SV[nodes[i].type]}-s)"/>`;});s+=`<circle cx="${PX}" cy="${cy}" r="${PR}" style="fill:var(--np-f);stroke:var(--np-s);stroke-width:0.5"/>`;s+=`<circle cx="${PX}" cy="${cy-5}" r="5" style="fill:var(--np-t)"/>`;s+=`<path d="M ${PX-9} ${cy+13} C ${PX-9} ${cy+4} ${PX+9} ${cy+4} ${PX+9} ${cy+13}" style="fill:none;stroke:var(--np-t);stroke-width:1.5;stroke-linecap:round"/>`;s+=`<text x="${PX}" y="${cy+PR+13}" text-anchor="middle" style="font-size:10px;font-family:var(--font-