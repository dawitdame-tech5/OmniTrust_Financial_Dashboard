document.getElementById('sortSel').addEventListener('change',e=>{srtMode=e.target.value;ekycRender();});
function toggleGuide(){const p=document.getElementById('guidePanel');p.style.display=p.style.display==='block'?'none':'block';}
function toggleSources(){const b=document.getElementById('sourcesBody'),a=document.getElementById('srcArrow'),o=b.style.display==='block';b.style.display=o?'none':'block';a.textContent=o?'▼':'▲';}
window.toggleGuide=toggleGuide;
window.toggleSources=toggleSources;
ekycRender();
