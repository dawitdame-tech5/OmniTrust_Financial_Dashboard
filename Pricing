<!-- ── Tab chrome ── -->
<div class="tabbar">
  <div class="tabbar-inner">
    <div class="tab-logo">
      <span class="t5-product">OmniTrust</span>
      <span class="t5-brand"><span class="t5-name">TECH5</span> Transaction Volumes &amp; Revenue Estimates</span>
    </div>
    <nav class="tabs" role="tablist">
      <button class="tab act" id="tab-0" role="tab" aria-selected="true"  aria-controls="panel-0" onclick="switchTab(0)">Use case &amp; pricing</button>
      <button class="tab"     id="tab-1" role="tab" aria-selected="false" aria-controls="panel-1" onclick="switchTab(1)">eKYC by country</button>
