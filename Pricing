.pehd{font-size:10px;font-weight:500;color:var(--color-text-secondary);margin-bottom:6px;display:flex;align-items:center;gap:6px}.pehd::after{content:'';flex:1;height:0.5px;background:var(--color-border-tertiary)}
.pb{font-size:11px;padding:4px 10px;border-radius:6px;border:0.5px solid var(--color-border-secondary);background:var(--color-background-secondary);color:var(--color-text-primary);cursor:pointer}.pb:hover,.pb.act{background:var(--color-background-info);color:var(--color-text-info);border-color:var(--color-border-info)}
