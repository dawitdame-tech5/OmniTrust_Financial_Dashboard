/* Service picker */
.sprow{display:flex;align-items:center;gap:6px;padding:7px 9px;border-radius:8px;cursor:pointer;margin-bottom:3px;border:0.5px solid transparent;user-select:none}.sprow:hover{background:var(--color-background-secondary)}.sprow.son{border-color:var(--color-border-tertiary)}
.spic{width:13px;height:13px;border-radius:50%;border:1.5px solid var(--color-border-secondary);flex-shrink:0}
.spnm{font-size:11px;font-weight:500;flex:1;min-width:55px}
.sploas{display:flex;gap:2px}
.splb{font-size:10px;padding:2px 6px;border-radius:4px;border:0.5px solid var(--color-border-tertiary);background:transparent;cursor:pointer;color:var(--color-text-secondary)}
.spcost{font-size:11px;font-weight:500;min-width:44px;text-align:right;font-family:var(--font-mono,monospace);color:var(--color-text-success)}
.sptot{display:flex;justify-content:space-between;align-items:center;padding:8px 9px 2px;border-top:0.5px solid var(--color-border-tertiary);margin-top:5px}

/* Breakdown table */
.bk{width:100%;border-collapse:collapse;font-size:11px}.bk th{padding:4px 8px;text-align:left;font-size:10px;font-weight:500;color:var(--color-text-secondary);border-bottom:0.5px solid var(--color-border-tertiary)}.bk th.r{text-align:right}.bk td{padding:5px 8px;border-bottom:0.5px solid var(--color-border-tertiary);color:var(--color-text-secondary)}.bk td.nd{font-weight:500;color:var(--color-text-primary);font-size:12px}.bk td.r{text-align:right}.bk td.tt{font-weight:500;color:var(--color-text-success);font-family:var(--font-mono,monospace);text-align:right}.bk .totrow td{border-top:0.5px solid var(--color-border-secondary);border-bottom:none;padding-top:7px}

/* Cost panel */
.ct{width:100%;border-collapse:collapse;font-size:11px}.ct th{padding:5px 6px;text-align:left;font-size:10px;font-weight:500;color:var(--color-text-secondary);border-bottom:0.5px solid var(--color-border-tertiary);white-space:nowrap}.ct td{padding:5px 6px;border-bottom:0.5px solid var(--color-border-tertiary);vertical-align:middle}.ct tr:last-child td{border-bottom:none}.ct .nm{font-size:11px;color:var(--color-text-primary)}.ct .asmpt{font-size:10px;color:var(--color-text-secondary);white-space:nowrap}.ct .ptx{font-size:12px;font-weight:500;color:var(--color-text-success);font-family:var(--font-mono);text-align:right;min-width:76px}.ct .grphd td{background:var(--color-background-secondary);padding:4px 6px;font-size:10px;font-weight:500;color:var(--color-text-secondary);border-bottom:0.5px solid var(--color-border-tertiary)}
.dt{width:100%;border-collapse:collapse;font-size:11px}.dt th{padding:4px 6px;text-align:right;font-size:10px;font-weight:500;color:var(--color-text-secondary);border-bottom:0.5px solid var(--color-border-tertiary);white-space:nowrap}.dt th.lc,.dt td.lc,.dt td.nd{text-align:left}.dt td{padding:4px 6px;text-align:right;border-bottom:0.5px solid var(--color-border-tertiary);font-size:11px;color:var(--color-text-secondary)}.dt td.nd{font-weight:500;color:var(--color-text-primary)}.dt td.drv{font-weight:500;color:var(--color-text-success)}.dt td.gm{font-weight:500;color:var(--ci-s)}
.pf{border:0.5px solid var(--color-border-tertiary);border-radius:8px;padding:10px 13px;background:var(--color-background-secondary);margin-top:12px}
input[type=number]{text-align:right;font-size:11px;padding:2px 4px;border-radius:5px;background:var(--color-background-primary);color:var(--color-text-primary);border:0.5px solid var(--color-border-tertiary);font-family:var(--font-mono)}
input[type=number]:focus{outline:none;border-color:var(--color-border-secondary)}
input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none}
/* ── Tab chrome ── */
.tabbar{position:sticky;top:0;z-index:100;background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);margin:-24px -24px 20px}
.tabbar-inner{display:flex;align-items:center;padding:0 24px;gap:0}
.tab-logo{font-size:12px;font-weight:500;color:var(--color-text-secondary);padding:12px 18px 12px 0;border-right:0.5px solid var(--color-border-tertiary);margin-right:4px;white-space:nowrap}
.tabs{display:flex;gap:0}
.tab{font-size:12px;padding:12px 16px;border:none;background:transparent;cursor:pointer;color:var(--color-text-secondary);border-bottom:2px solid transparent;transition:color .15s,border-color .15s;white-space:nowrap}
.tab:hover{color:var(--color-text-primary)}
