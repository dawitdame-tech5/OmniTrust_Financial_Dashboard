,"sector":"Other Services","name":"Gaming or lottery — Player age-verification","svcs":{"ekyc":null,"ci":null,"cv":"L1","auth":"L1","pay":null}},{"id":"UC-30-008","sector":"Other Services","name":"Prize claim — Identity verification & payout","svcs":{"ekyc":"T1","ci":null,"cv":"L1","auth":"L1","pay":null}}];
