}
.page-header{margin-bottom:16px}.page-header h1{font-size:15px;font-weight:500}.page-header p{font-size:12px;color:var(--color-text-secondary);margin-top:3px}
.pnl{border:0.5px solid var(--color-border-tertiary);border-radius:12px;padding:13px 15px;background:var(--color-background-primary)}
